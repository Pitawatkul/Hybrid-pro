# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# next-pwa generated service worker artifacts
/public/sw.js
/public/swe-worker*.js
/public/workbox-*.js
/public/worker-*.js
/public/fallback-*.js
/public/*.js.map

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# claude code session-local state (launch.json is shared, kept tracked)
.claude/settings.local.json
.claude/scheduled_tasks.lock

# typescript
*.tsbuildinfo
next-env.d.ts
